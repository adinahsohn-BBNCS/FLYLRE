# Fly LRE — copy to .env and fill in (never commit .env)

# Supabase (pilot submissions + admin)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# Form notifications (FormSubmit)
PUBLIC_NOTIFY_EMAIL=info@flylre.com

# Onsite weather (Weather Underground PWS KCAAGUAN61 — 54CL Lake Riverside)
PUBLIC_WEATHER_STATION_ID=KCAAGUAN61
PUBLIC_WEATHER_API_KEY=your-weather-underground-api-key

# Liquid Web SFTP deploy (npm run deploy)
# Credentials: Site Dashboard → SFTP/SSH
SFTP_HOST=your-site.sftp.host
SFTP_PORT=22
SFTP_USER=your-sftp-username
SFTP_PASSWORD=your-sftp-password
SFTP_REMOTE_DIR=/chroot/home/YOUR_ACCOUNT/flylre.com/html
