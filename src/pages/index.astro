---
import BaseLayout from "../layouts/BaseLayout.astro";
import WeatherStation from "../components/WeatherStation.astro";
---

<BaseLayout title="Fly LRE" current="home">
  <div class="page page-home">
    <header class="hero">
      <img
        class="hero-brand"
        src="/images/LRE.png"
        alt="Fly LRE — Lake Riverside Estates. Adventure Begins at the End of the Runway."
        width="640"
        height="640"
        fetchpriority="high"
      />
      <p class="hero-support">
        Proud to support emergency medical, fire, and public safety operations.
      </p>
      <p class="hero-sub">
        For pilots at Lake Riverside Estates — and friends invited to visit.
        Visitors welcome with prior permission from residents.
      </p>
    </header>

    <aside id="airport-notam" class="airport-notam" role="alert" hidden>
      <p class="airport-notam-eyebrow">NOTAM — Airport Closed</p>
      <h2 class="airport-notam-title">54CL — Lake Riverside Estates is closed</h2>
      <p id="airport-notam-reason" class="airport-notam-reason"></p>
      <dl class="airport-notam-times">
        <div>
          <dt>Closed from</dt>
          <dd id="airport-notam-closes"></dd>
        </div>
        <div>
          <dt>Expected reopening</dt>
          <dd id="airport-notam-opens"></dd>
        </div>
      </dl>
    </aside>

    <div class="card-grid">
      <a class="card" href="/explore-the-airport/">
        <h2>Explore the Airport</h2>
        <p>Runway info, airspace, and everything you need before flying in as a guest.</p>
        <span class="card-arrow">View airport →</span>
      </a>
      <a class="card" href="/plan-your-next-adventure/">
        <h2>Plan Your Next Adventure</h2>
        <p>Suggested fly-outs from 54CL — local hops pilots from the community enjoy.</p>
        <span class="card-arrow">See destinations →</span>
      </a>
    </div>

    <WeatherStation />

    <section id="pilot-spotlight" class="pilot-spotlight" hidden>
      <p class="pilot-spotlight-eyebrow">Pilot Spotlight</p>
      <h2 class="pilot-spotlight-title">A pilot at LRE</h2>
      <p id="pilot-spotlight-loading" class="pilot-loading">Loading pilot spotlight…</p>
      <article id="pilot-spotlight-card" class="pilot-spotlight-card" hidden></article>
      <p class="pilot-spotlight-link">
        <a href="/meet-the-planes/">Meet the planes →</a>
      </p>
    </section>

    <div class="cta-box">
      <p><strong>Planning a visit?</strong></p>
      <p>
        Visitors welcome with prior permission from residents. Before you fly in, please take a
        moment to review the
        <a href="/explore-the-airport/#airport-rules">airport rules</a> and
        <a href="/explore-the-airport/#airport-diagram">airport diagram</a>.
      </p>
    </div>
  </div>
</BaseLayout>

<script>
  import "../scripts/airport-notam.ts";
  import "../scripts/pilot-spotlight.ts";
</script>
